[advice]
	detachedHead = false
[clean]
	requireForce = false
[color]
	branch = always
	diff = always
	status = always
[color "branch"]
	current = green bold
[color "diff"]
	meta = dim
	old = red black
[color "status"]
	localBranch = green bold
	remoteBranch = red bold
[commit]
	gpgsign = false
[core]
	abbrev = 8
	autocrlf = input
	pager = delta
	safecrlf = false
	whitespace = cr-at-eol
[delta]
	commit-decoration-style = "#202020" ol
	commit-regex = ^commit:
	commit-style = raw
	file-decoration-style = none
	file-style = dim
	hunk-header-decoration-style = none
	hunk-header-style = omit
	hyperlinks = false
	line-numbers = true
	line-numbers-left-format = " {nm:6}"
	line-numbers-left-style = auto "#501010"
	line-numbers-minus-style = "#909090" "#000000"
	line-numbers-plus-style = "#909090" "#000000"
	line-numbers-right-format = " {nm:6}"
	line-numbers-right-style = auto "#104010"
	line-numbers-zero-style = "#909090" "#101010"
	minus-empty-line-marker-style = auto "#501010"
	minus-emph-style = "#000000" "#904040"
	minus-non-emph-style = auto "#501010"
	minus-style = auto "#501010"
	plus-emph-style = "#000000" "#409040"
	plus-empty-line-marker-style = auto "#104010"
	plus-non-emph-style = auto "#104010"
	plus-style = auto "#104010"
	right-arrow = ->
	side-by-side = false
	syntax-theme = none
	tabs = 4
	zero-style = auto "#101010"
[diff]
	algorithm = minimal
	context = 2
[fetch]
	prune = true
[format]
	pretty = format:"%C(auto)commit: %H%d%nauthor: %an <%ae>%ndate:   %ad%n%n%s"
[init]
	defaultBranch = main
[interactive]
	diffFilter = delta --color-only --width=variable
[log]
	date = iso
[merge]
	ff = false
[pull]
	ff = only
[push]
	autoSetupRemote = true
	default = simple
[user]
	email = tyholling@gmail.com
	name = Tyler Hollingsworth
